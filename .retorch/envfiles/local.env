# Local defaults for the RETORCH social network test suite
# Adjust these values to match your local environment before running the helper scripts.

# Base URL used by the tests when no explicit SUT URL is provided.
SUT_URL=http://localhost:8080

# Disable Selenoid by default for local runs.
SELENOID_PRESENT=false

# Docker Compose project name used by the local redeploy helpers.
COMPOSE_PROJECT_NAME=local

# Compose files to use for local deployment.
# The scripts resolve relative paths from the repository root.
COMPOSE_FILE=docker-compose.yml
COMPOSE_OVERRIDE_FILE=docker-compose.local-override.yml
